#!/bin/sh

# Attach to the single persistent Hermes TUI hosted on curiosity.
# Advertise a widely supported terminal type to the Pi, regardless of the
# terminal emulator used locally. -A creates the session when absent; -D hands
# control over from another client.
TERM=xterm-256color
export TERM
exec ssh -t curiosity 'PATH="$HOME/.local/bin:$PATH"; export PATH; exec tmux new-session -A -D -s hermes -c /home/swarnim/ai "exec hermes --tui"'
